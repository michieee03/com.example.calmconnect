<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="56dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎮 Mindful Games"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/calm_text"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Play simple calming games to relax and focus"
                android:textSize="13sp"
                android:textColor="@color/calm_subtext"
                android:layout_marginBottom="20dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTapping"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFFCC">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:text="👆"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:background="@drawable/bg_tool_card_peach"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tapping Game" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/calm_text" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tap as fast as you can!" android:textSize="12sp" android:textColor="@color/calm_subtext" android:layout_marginTop="2dp" />
                        <TextView android:id="@+id/tvTappingHighScore" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="High Score: 0" android:textSize="12sp" android:textColor="#4CAF93" android:textStyle="bold" android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="22sp" android:textColor="#4CAF93" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMemory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFFCC">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:text="🧠"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:background="@drawable/bg_tool_card_lavender"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Memory Cards" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/calm_text" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Find all matching pairs" android:textSize="12sp" android:textColor="@color/calm_subtext" android:layout_marginTop="2dp" />
                        <TextView android:id="@+id/tvMemoryHighScore" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="High Score: 0" android:textSize="12sp" android:textColor="#4CAF93" android:textStyle="bold" android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="22sp" android:textColor="#4CAF93" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBreathingGame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFFCC">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:text="🌬"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:background="@drawable/bg_tool_card_green"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Breathing Exercise" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/calm_text" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Follow the calm breathing circle" android:textSize="12sp" android:textColor="@color/calm_subtext" android:layout_marginTop="2dp" />
                        <TextView android:id="@+id/tvBreathingGameHighScore" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="High Score: 0" android:textSize="12sp" android:textColor="#4CAF93" android:textStyle="bold" android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="22sp" android:textColor="#4CAF93" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/btnClose"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:text="✕"
        android:textSize="16sp"
        android:textColor="@color/calm_text"
        android:gravity="center"
        android:background="@drawable/bg_card_white" />

</FrameLayout>
