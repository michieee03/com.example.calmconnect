<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_game_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Memory Cards"
            android:textColor="@color/calm_text"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvMoves"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Moves: 0"
            android:textColor="@color/calm_primary_dark"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPairs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Matched Pairs: 0 / 6"
            android:textColor="@color/calm_subtext"
            android:textSize="15sp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="18dp" />

        <GridLayout
            android:id="@+id/gridMemory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="4"
            android:useDefaultMargins="true">

            <Button
                android:id="@+id/card1"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_memory_card_hidden"
                android:text="?"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="24sp" />

            <Button
                android:id="@+id/card2"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_memory_card_hidden"
                android:text="?"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="24sp" />

            <Button
                android:id="@+id/card3"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_memory_card_hidden"
                android:text="?"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="24sp" />

            <Button
                android:id="@+id/card4"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_memory_card_hidden"
                android:text="?"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="24sp" />

            <Button
                android:id="@+id/card5"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_memory_card_hidden"
                android:text="?"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="24sp" />

            <Button
                android:id="@+id/card6"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_memory_card_hidden"
                android:text="?"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="24sp" />

            <Button
                android:id="@+id/card7"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_memory_card_hidden"
                android:text="?"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="24sp" />

            <Button
                android:id="@+id/card8"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_memory_card_hidden"
                android:text="?"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="24sp" />

            <Button
                android:id="@+id/card9"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_memory_card_hidden"
                android:text="?"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="24sp" />

            <Button
                android:id="@+id/card10"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_memory_card_hidden"
                android:text="?"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="24sp" />

            <Button
                android:id="@+id/card11"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_memory_card_hidden"
                android:text="?"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="24sp" />

            <Button
                android:id="@+id/card12"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_memory_card_hidden"
                android:text="?"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="24sp" />
        </GridLayout>

        <TextView
            android:id="@+id/tvMemoryResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Match all the pairs."
            android:textColor="@color/calm_subtext"
            android:textSize="15sp"
            android:layout_marginTop="18dp" />

        <Button
            android:id="@+id/btnRestartMemory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Restart"
            android:textAllCaps="false"
            android:layout_marginTop="18dp" />
    </LinearLayout>
</ScrollView>