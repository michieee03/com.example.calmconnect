<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_mood_entry_card"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="14dp"
    android:layout_marginBottom="10dp">

    <!-- Quote mark accent -->
    <TextView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:gravity="center"
        android:text="\u201C"
        android:textSize="22sp"
        android:textColor="#4CAF93"
        android:fontFamily="serif"
        android:background="@drawable/bg_health_card"
        android:layout_marginEnd="12dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvItemQuoteText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/calm_text"
            android:fontFamily="serif"
            android:textStyle="italic"
            android:maxLines="3"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvItemQuoteAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="11sp"
            android:textColor="#4CAF93"
            android:textStyle="bold"
            android:textAlignment="textEnd" />

    </LinearLayout>

</LinearLayout>
