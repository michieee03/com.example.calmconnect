<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_mood_entry_card"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Colored accent bar on the left -->
        <View
            android:id="@+id/viewAccentBar"
            android:layout_width="4dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_mood_accent_bar"
            android:layout_marginEnd="12dp" />

        <!-- Emoji circle -->
        <TextView
            android:id="@+id/tvEmoji"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:textSize="22sp"
            android:background="@drawable/bg_emotion_item"
            android:layout_marginEnd="12dp" />

        <!-- Emotion + date column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvEmotion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/calm_text" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="11sp"
                android:textColor="@color/calm_subtext" />

            <TextView
                android:id="@+id/tvNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="12sp"
                android:textColor="#5A748A"
                android:fontFamily="serif"
                android:textStyle="italic"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Mood level indicator dots -->
        <LinearLayout
            android:id="@+id/llMoodDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>
