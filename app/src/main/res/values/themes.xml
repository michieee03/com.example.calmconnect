<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CalmConnect" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/calm_primary</item>
        <item name="colorPrimaryVariant">@color/calm_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/gradient_start</item>
        <item name="colorSecondaryVariant">@color/gradient_end</item>
        <item name="colorOnSecondary">@color/calm_text</item>
        <item name="android:windowBackground">@drawable/bg_app_gradient</item>
        <item name="android:statusBarColor">@color/gradient_start</item>
        <item name="android:navigationBarColor">@color/gradient_end</item>
        <item name="android:windowLightStatusBar">true</item>
        <!-- Semantic text colors for layouts -->
        <item name="android:textColorPrimary">@color/calm_text</item>
        <item name="android:textColorSecondary">@color/calm_subtext</item>
        <item name="android:textColorHint">@color/calm_subtext</item>
    </style>

    <style name="Theme.CalmConnect.Splash" parent="Theme.CalmConnect">
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Circular image shape for profile avatar -->
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Input field focused stroke uses calm_primary -->
    <style name="CalmInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/input_stroke_selector</item>
        <item name="hintTextColor">@color/calm_primary</item>
    </style>
</resources>